# Admin sayfası: ?token=GIZLI_SIFRE (canlıda alt alan adı ile aşağıya bakın)
ADMIN_DEMO_TOKEN=

# Canlıda yönetim paneli için alt alan adı (örn. admin.eleythra.com). DNS’te bu host’u Vercel projesine ekleyin.
# Boş bırakılırsa panel /admin/demo-talepleri?token=... adresinde kalır (localhost için uygun).
# Vercel: Bu değişkeni yalnızca Production’a vermek iyi olur; Preview branch’lerde /admin yolu çalışmaya devam eder.
ADMIN_HOST=

# Ana site URL’i (token hatalı yönlendirmesi ve “Ana site” linki)
NEXT_PUBLIC_SITE_URL=https://eleythra.com

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
